#!/bin/bash

#
# Instruqt Setup Script – App Migration Lab
#

echo "🚀 Starting setup script for App Migration Lab..."
set -euxo pipefail

set-workdir /root/infoblox-lab

# Navigate to script folder
cd /root/infoblox-lab/app-migration-lab/terraform/scripts || {
    echo "❌ Could not access script directory."
    exit 1
}

# Wait for CSP sandbox propagation (8 mins)
echo "⏳ Waiting 8 minutes for CSP sandbox propagation..."
sleep 480

# === Discovery Deployment ===
echo "📦 Deploying AWS Discovery..."
python3 deploy_aws_discovery_final.py
sleep 360

# === IPAM Config ===
echo "🧠 Deploying IPAM configuration..."
python3 deploy_ipam.py
sleep 30

# === API Key ===
echo "🔐 Deploying API key..."
python3 deploy_api_key.py

# Reload environment variables if needed
source /root/.bashrc || true

echo "✅ Setup complete!"
exit 0